{
  "name": "@citera/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./src/schema.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "lint": "eslint src drizzle.config.ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.. packages/database/src"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260712.1",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
