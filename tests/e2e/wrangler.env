# Non-secret bindings used only by the local Playwright Worker.
ENVIRONMENT=test
APP_ORIGIN=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173
AUTH_DEV_BYPASS=true
TOKEN_HASH_PEPPER=e2e-token-hash-pepper-not-for-production
IP_HASH_SALT=e2e-ip-hash-salt-not-for-production
MAX_PDF_BYTES=10485760
PRESIGN_TTL_SECONDS=300
